PORT=3002

# Postgres (Supabase pooler or local). Each app uses its own database.
DRIZZLE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_agent_b

# Branding
NEXT_PUBLIC_APP_NAME=Lakbay
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Network — the app pins signing to this network, not the wallet's active one.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC + the deployed TravelFundPool contract (testnet).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
TRAVEL_FUND_CONTRACT_ID=CC6YMREXBYOITKX26BTDBGQ55AGRJ6RRGEBNMI3O4V6G2ZB45ZAB5H4T
NEXT_PUBLIC_TRAVEL_FUND_CONTRACT_ID=CC6YMREXBYOITKX26BTDBGQ55AGRJ6RRGEBNMI3O4V6G2ZB45ZAB5H4T
# Native XLM Stellar Asset Contract (SAC) on testnet — the pool's settlement token (no trustline).
XLM_SAC_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Session (SEP-10) — must be at least 32 characters.
SESSION_SECRET=change-me-at-least-32-characters-long
SESSION_COOKIE_NAME=lakbay_session
SESSION_TTL_SECONDS=86400

# USDC opt-in asset (Circle testnet issuer)
USDC_ASSET_CODE=USDC
USDC_ASSET_ISSUER_TESTNET=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

DEMO_MODE=true
